<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<VBox spacing="16" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.baoths.controller.WebcamController">
    <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

    <Label text="Quét QR Code từ Webcam" styleClass="label-title"/>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Left: Webcam View -->
        <VBox spacing="12" HBox.hgrow="ALWAYS" alignment="TOP_CENTER">
            <StackPane fx:id="pnlWebcamView" styleClass="webcam-view" minHeight="400" maxWidth="Infinity">
                <ImageView fx:id="imgWebcam" preserveRatio="true" fitWidth="640" fitHeight="480"/>
                <Label fx:id="lblWebcamPlaceholder" text="📷 Webcam chưa khởi động"
                       styleClass="label-subtitle" style="-fx-text-fill: #888;"/>
            </StackPane>

            <HBox spacing="10" alignment="CENTER">
                <Button fx:id="btnStartCamera" text="▶ Bắt đầu" styleClass="button-success"
                        onAction="#handleStartCamera"/>
                <Button fx:id="btnStopCamera" text="⏹ Dừng" styleClass="button-danger"
                        onAction="#handleStopCamera" disable="true"/>
            </HBox>

            <Label fx:id="lblWebcamStatus" text="" styleClass="label-status"/>
        </VBox>

        <!-- Right: Scan Result -->
        <VBox spacing="12" HBox.hgrow="SOMETIMES" minWidth="280" styleClass="card">
            <Label text="Kết quả quét" styleClass="label-subtitle"/>

            <TextArea fx:id="txaWebcamResult" editable="false" wrapText="true"
                      promptText="Kết quả quét sẽ hiển thị ở đây..."
                      VBox.vgrow="ALWAYS" prefRowCount="10"/>

            <Label fx:id="lblScanCount" text="Đã quét: 0 mã" styleClass="label-status"/>

            <HBox spacing="10">
                <Button fx:id="btnCopyWebcamResult" text="📋 Copy" onAction="#handleCopyWebcamResult" disable="true"/>
                <Button fx:id="btnClearWebcamResult" text="🗑️ Xoá" onAction="#handleClearWebcamResult"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
